# Nusxa oling: cp .env.example .env  — va qiymatlarni to'ldiring.

# SQLite baza fayli (prisma/dev.db ga nisbatan schema.prisma joylashuvi)
DATABASE_URL="file:./dev.db"

# Sessiya cookie'lari uchun maxfiy kalit (istalgan uzun tasodifiy satr)
SESSION_SECRET="change-me-to-a-long-random-string"

# BotFather'dan olingan Telegram bot tokeni (TMA initData validatsiyasi uchun)
TELEGRAM_BOT_TOKEN="123456789:AA..."

# Google Stitch API kaliti (faqat stitch:list / stitch:fetch skriptlari uchun, ixtiyoriy)
STITCH_API_KEY=""
